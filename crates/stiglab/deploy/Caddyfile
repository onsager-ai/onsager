# Production edge dispatcher. Caddy is the only externally-reachable
# process in the Railway single-container image; everything below sits
# on loopback.
#
# Routing model (peer of deploy/dev/Caddyfile, with loopback upstreams):
#   /agent/ws*  → 127.0.0.1:3002  (portal — proxies to stiglab on loopback per ADR 0008)
#   /api/*      → 127.0.0.1:3002  (portal — ADR 0006)
#   /mcp/*      → 127.0.0.1:3002  (portal — MCP server for AI clients per ADR 0007)
#   /assets/*   → /app/static/assets (content-hashed, year-long immutable cache)
#   /*          → /app/static/index.html (SPA shell, no-cache)
#
# Railway injects $PORT; Caddy binds to it as the foreground process.
{
	admin off
	auto_https off
	persist_config off
}

:{$PORT} {
	log {
		output stdout
		format console
		level INFO
	}

	# Agent control plane WebSocket. Portal terminates the upgrade and
	# transparently forwards bytes to stiglab on loopback
	# (ws://127.0.0.1:3000/agent/ws-internal). See ADR 0008.
	handle /agent/ws* {
		reverse_proxy 127.0.0.1:3002
	}

	# Portal owns every dashboard-facing /api/* route (ADR 0006).
	handle /api/* {
		reverse_proxy 127.0.0.1:3002
	}

	# MCP server (ADR 0007 / #288). Runtime-agnostic public contract
	# for AI clients — same upstream as /api/* (portal owns clause 1
	# of the seam rule).
	handle /mcp/* {
		reverse_proxy 127.0.0.1:3002
	}

	# Static assets — Vite content-hashes filenames so a year-long
	# immutable cache is safe; a stale hash simply 404s and the SPA
	# shell (served with no-cache below) re-fetches the index.html
	# whose script tags now point at the new hashes. Caddy's
	# Caddyfile DSL has no top-level `status` response matcher, so
	# we apply the header unconditionally on this path prefix — fine
	# because misses on this prefix are themselves stable over time.
	@assets path /assets/*
	handle @assets {
		root * /app/static
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# SPA shell + everything else — no-cache so a new deploy is picked
	# up on the next navigation. `try_files` falls back to index.html
	# for client-side routes.
	handle {
		root * /app/static
		try_files {path} /index.html
		header Cache-Control "no-cache"
		file_server
	}
}
